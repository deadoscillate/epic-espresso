{
  "rules": {
    "coffee": {
      ".read": true,
      ".write": true,
      ".validate": "newData.hasChildren(['status', 'message', 'updatedAt'])",
      "status": {
        ".validate": "newData.isString() && newData.val().length <= 32"
      },
      "message": {
        ".validate": "newData.isString() && newData.val().length <= 280"
      },
      "updatedAt": {
        ".validate": "newData.isNumber()"
      }
    }
  }
}
